// ---------------------------------------------------------------------------
// Slotted Test Agent — Environment Configuration
// ---------------------------------------------------------------------------
// Copy this to .env and fill in real values.
//
//   cp .env.example .env
//
// NEVER commit the .env file — it contains secrets.
// ---------------------------------------------------------------------------

// Base URL of the Slotted API (Firebase Functions)
API_BASE_URL=https://slotted-ai.web.app/api

// Admin secret (same as ADMIN_SECRET in functions/.env)
ADMIN_SECRET=slotted-admin-2026

// Path to a Firebase service account JSON key file.
# Download from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

// ---------------------------------------------------------------------------
// Test Agent Google Accounts
// Create 3 dummy Google accounts and register them in Slotted.
// Then fill in their Firebase UIDs here (find them via Firebase Console → Authentication).
// ---------------------------------------------------------------------------

# Agent 1 — "The Planner"
AGENT1_EMAIL=slotted.tester1@gmail.com
AGENT1_FIREBASE_UID=

# Agent 2 — "The Spontaneous One"
AGENT2_EMAIL=slotted.tester2@gmail.com
AGENT2_FIREBASE_UID=

# Agent 3 — "The Flaky One"
AGENT3_EMAIL=slotted.tester3@gmail.com
AGENT3_FIREBASE_UID=
