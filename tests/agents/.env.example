// ---------------------------------------------------------------------------
// Slotted Test Agent — Environment Configuration
// ---------------------------------------------------------------------------
// Copy this to .env and fill in real values.
//
//   cp .env.example .env
//
// NEVER commit the .env file — it contains secrets.
// ---------------------------------------------------------------------------

// Base URL of the Slotted API (Firebase Functions)
API_BASE_URL=https://slottedapp.com/api

// Admin secret (same as ADMIN_SECRET in functions/.env)
ADMIN_SECRET=slotted-admin-2026

// Firebase Web API Key (public browser key)
# Find at Firebase Console → Project Settings → General → Web API Key
FIREBASE_API_KEY=

// ---------------------------------------------------------------------------
// Test Agent Accounts
// Accounts are auto-created by `npm run setup` using email/password auth.
// Firebase UIDs are auto-populated after first setup run.
// ---------------------------------------------------------------------------

# Agent 1 — "The Planner"
AGENT1_EMAIL=slotted.tester1@gmail.com
AGENT1_FIREBASE_UID=

# Agent 2 — "The Spontaneous One"
AGENT2_EMAIL=slotted.tester2@gmail.com
AGENT2_FIREBASE_UID=

# Agent 3 — "The Flaky One"
AGENT3_EMAIL=slotted.tester3@gmail.com
AGENT3_FIREBASE_UID=
